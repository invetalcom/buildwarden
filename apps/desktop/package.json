{
  "name": "@buildwarden/desktop",
  "version": "0.6.1",
  "releaseDate": "2026-07-17",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "description": "Desktop GUI for coding agents",
  "homepage": "https://r-kellner.de",
  "author": {
    "name": "Rudolf Kellner",
    "email": "ai-support@r-kellner.de"
  },
  "scripts": {
    "build": "electron-vite build && pnpm build:web && electron-builder",
    "build:web": "pnpm --filter @buildwarden/web build:embedded",
    "build:win": "electron-vite build && pnpm build:web && electron-builder --win",
    "build:win:portable": "electron-vite build && pnpm build:web && electron-builder --win portable",
    "build:linux": "electron-vite build && pnpm build:web && electron-builder --linux",
    "build:linux:appimage": "electron-vite build && pnpm build:web && electron-builder --linux AppImage",
    "build:linux:deb": "electron-vite build && pnpm build:web && electron-builder --linux deb",
    "build:mac": "electron-vite build && pnpm build:web && electron-builder --mac",
    "build:all": "electron-vite build && pnpm build:web && electron-builder -mwl",
    "dev": "electron-vite dev",
    "lint": "eslint . --ext .ts,.tsx",
    "pack": "electron-builder --dir",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@buildwarden/agent-runtime": "workspace:*",
    "@buildwarden/db": "workspace:*",
    "@buildwarden/git-service": "workspace:*",
    "@buildwarden/provider-ai-sdk": "workspace:*",
    "@buildwarden/provider-azure-legacy": "workspace:*",
    "@buildwarden/provider-claude-code": "workspace:*",
    "@buildwarden/provider-codex-cli": "workspace:*",
    "@buildwarden/provider-cursor-agent": "workspace:*",
    "@buildwarden/remote-server": "workspace:*",
    "@buildwarden/renderer": "workspace:*",
    "@buildwarden/shared": "workspace:*",
    "@medv/finder": "4.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "diff": "^8.0.3",
    "gpt-tokenizer": "^3.4.0",
    "node-pty": "^1.1.0",
    "openai": "^5.12.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-git": "^3.36.0",
    "sql.js": "^1.13.0",
    "tailwindcss": "^4.3.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@swc/core": "^1.15.18",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-istanbul": "4.1.9",
    "ai": "7.0.20",
    "electron": "^41.9.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-sonarjs": "^4.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.buildwarden.desktop",
    "productName": "BuildWarden",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "dist/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icons/icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icons/icon.ico"
      }
    ],
    "asarUnpack": [
      "**/*.wasm",
      "**/node_modules/node-pty/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "executableName": "buildwarden",
      "target": [
        "tar.xz"
      ],
      "category": "Development"
    },
    "deb": {
      "packageName": "buildwarden"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
