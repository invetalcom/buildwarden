{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@buildwarden/shared": ["packages/shared/src/index.ts"],
      "@buildwarden/shared/*": ["packages/shared/src/*"],
      "@buildwarden/db": ["packages/db/src/index.ts"],
      "@buildwarden/db/*": ["packages/db/src/*"],
      "@buildwarden/git-service": ["packages/git-service/src/index.ts"],
      "@buildwarden/git-service/*": ["packages/git-service/src/*"],
      "@buildwarden/agent-runtime": ["packages/agent-runtime/src/index.ts"],
      "@buildwarden/agent-runtime/*": ["packages/agent-runtime/src/*"],
      "@buildwarden/provider-ai-sdk": ["packages/provider-ai-sdk/src/index.ts"],
      "@buildwarden/provider-ai-sdk/*": ["packages/provider-ai-sdk/src/*"],
      "@buildwarden/provider-codex-cli": ["packages/provider-codex-cli/src/index.ts"],
      "@buildwarden/provider-codex-cli/*": ["packages/provider-codex-cli/src/*"],
      "@buildwarden/provider-claude-code": ["packages/provider-claude-code/src/index.ts"],
      "@buildwarden/provider-claude-code/*": ["packages/provider-claude-code/src/*"],
      "@buildwarden/provider-azure-legacy": ["packages/provider-azure-legacy/src/index.ts"],
      "@buildwarden/provider-azure-legacy/*": ["packages/provider-azure-legacy/src/*"],
      "@buildwarden/provider-openai": ["packages/provider-openai/src/index.ts"],
      "@buildwarden/provider-openai/*": ["packages/provider-openai/src/*"],
      "@buildwarden/provider-openai-compatible": ["packages/provider-openai-compatible/src/index.ts"],
      "@buildwarden/provider-openai-compatible/*": ["packages/provider-openai-compatible/src/*"]
    }
  }
}
