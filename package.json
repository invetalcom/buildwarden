{
  "name": "buildwarden",
  "version": "0.5.4",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Desktop GUI for coding agents",
  "scripts": {
    "analyze": "pnpm analyze:eslint && pnpm analyze:deps && pnpm analyze:duplicates && pnpm analyze:unused",
    "analyze:deps": "dependency-cruiser --config .dependency-cruiser.cjs apps/desktop/src packages --output-type err",
    "analyze:duplicates": "jscpd --config .jscpd.json apps packages",
    "analyze:eslint": "node scripts/analyze-eslint.mjs",
    "analyze:unused": "knip --config knip.json",
    "quality:score": "pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm --filter @buildwarden/desktop exec electron-vite build && pnpm analyze:unused && pnpm analyze:deps && node scripts/quality-score.mjs",
    "build": "pnpm --filter @buildwarden/desktop build",
    "build:win": "pnpm --filter @buildwarden/desktop build:win",
    "build:win:portable": "pnpm --filter @buildwarden/desktop build:win:portable",
    "build:linux": "pnpm --filter @buildwarden/desktop build:linux",
    "build:linux:appimage": "pnpm --filter @buildwarden/desktop build:linux:appimage",
    "build:linux:deb": "pnpm --filter @buildwarden/desktop build:linux:deb",
    "build:mac": "pnpm --filter @buildwarden/desktop build:mac",
    "build:all": "pnpm --filter @buildwarden/desktop build:all",
    "dev": "pnpm --filter @buildwarden/desktop dev",
    "lint": "pnpm --filter @buildwarden/desktop lint && pnpm --filter @buildwarden/desktop test",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:prepare:usage": "node scripts/prepare-release.mjs --help",
    "test": "pnpm --filter @buildwarden/desktop test",
    "test:coverage": "pnpm --filter @buildwarden/desktop test:coverage",
    "typecheck": "pnpm --filter @buildwarden/desktop typecheck"
  },
  "devDependencies": {
    "dependency-cruiser": "17.3.10",
    "jscpd": "5.0.12",
    "knip": "6.26.0"
  }
}
